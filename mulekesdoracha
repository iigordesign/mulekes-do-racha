function processarLista(){
  const raw=document.getElementById('lista-input').value.trim();
  if(!raw)return;
  semanaAtual=[];
  raw.split('\n').map(l=>l.trim()).filter(l=>l).forEach(linha=>{
    const m=linha.match(/^(\d+)\s*[-–]\s*(.+)/);
    if(!m)return;
    let resto=m[2].trim();
    let posStr='';
    const parts=resto.split(/\s*[-–]\s*/);
    let nomeParte=resto;
    if(parts.length>=2){
      const ult=parts[parts.length-1].toUpperCase();
      if(/^(ATA|MEI|ZAG|LAT|VOL)/.test(ult)){posStr=parts[parts.length-1];nomeParte=parts.slice(0,-1).join(' - ');}
    }
    let nomeBase=nomeParte.trim(),convidadoPor='';
    const mc=nomeBase.match(/^(.+?)\s*\((.+?)\)\s*$/);
    if(mc){nomeBase=mc[1].trim();convidadoPor=mc[2].trim();}
    const posArr=posStr?posStr.split(',').map(p=>p.trim().toUpperCase()).filter(p=>['ATA','MEI','ZAG','LAT','VOL'].includes(p)):[];
    const idx=findJ(nomeBase);
    const db=idx>=0?state.jogadores[idx]:null;
    semanaAtual.push({num:parseInt(m[1]),nome:nomeBase,convidadoPor,posLista:posArr,dbIdx:idx,estrelas:db?db.s:3,selected:true});
  });
  renderParsed();
  document.getElementById('parsed-area').style.display='block';
}

function renderParsed(){
  const grid=document.getElementById('players-grid');
  grid.innerHTML='';
  selecionados.clear();
  semanaAtual.forEach((j,i)=>{
    if(j.selected)selecionados.add(i);
    const div=document.createElement('div');
    div.className='pc'+(j.selected?' sel':'')+(j.convidadoPor?' conv':'');
    div.id='pc'+i;
    const db=j.dbIdx>=0?state.jogadores[j.dbIdx]:null;
    const pos=j.posLista.length?j.posLista.join('/'):db?posPosicoes(db.p,db.p2):'?';
    div.innerHTML=`<div class="pc-num">${j.num}</div><div class="pc-info">
