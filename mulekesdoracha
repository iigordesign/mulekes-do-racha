function updCtrl(){
  const t=selecionados.size;
  const info=document.getElementById('sctrl-info');
  const btn=document.getElementById('btn-sortear');
  const b=Math.floor(t/4),ex=t%4;
  if(t<8){info.innerHTML=`<strong>${t}</strong> selecionados — mínimo 8`;btn.disabled=true;}
  else{info.innerHTML=`<strong>${t}</strong> jogadores → 4 times de ~<strong>${b}</strong>${ex?` (${ex} com ${b+1})`:''}`;btn.disabled=false;}
}
function resetSorteio(){document.getElementById('times-area').innerHTML='';document.getElementById('lista-input').value='';document.getElementById('parsed-area').style.display='none';semanaAtual=[];selecionados.clear();}

function sortear(){
  const sel=semanaAtual.filter((_,i)=>selecionados.has(i));
  if(sel.length<8)return;
  const n=sel.length,base=Math.floor(n/4),ex=n%4;
  const sizes=[base,base,base,base];
  for(let i=0;i<ex;i++)sizes[i]++;
  const comPeso=sel.map(j=>{const db=j.dbIdx>=0?state.jogadores[j.dbIdx]:null;return{...j,peso:(j.estrelas*10)+(db?(db.mvp||0)*1.5+(db.camp||0)*2+Math.min(db.gols||0,30)*.08:0)};});
  const sorted=[...comPeso].sort((a,b)=>b.peso-a.peso);
  const grupos=[];
  for(let i=0;i<sorted.length;i+=4)grupos.push(shuffle(sorted.slice(i,i+4)));
  const times=[[],[],[],[]],pesoTimes=[0,0,0,0];
  grupos.forEach(grp=>{
    const ord=shuffle([0,1,2,3]);
    grp.forEach((j,idx)=>{
      let ti=ord[idx];
      if(times[ti].length>=sizes[ti]){const livre=[0,1,2,3].filter(t=>times[t].length<sizes[t]);ti=livre.reduce((a,b)=>pesoTimes[a]<=pesoTimes[b]?a:b);}
      times[ti].push(j);pesoTimes[ti]+=j.peso;
    });
  });
  const CORES=[{nome:'Time Verde',cor:'#4CAF7D',bg:'rgba(76,175,125,.15)'},{nome:'Time Azul',cor:'#4A9EFF',bg:'rgba(74,158,255,.15)'},{nome:'Time Laranja',cor:'#FF6B35',bg:'rgba(255,107,53,.15)'},{nome:'Time Dourado',cor:'#D3B474',bg:'rgba(211,180,116,.15)'}];
  const area=document.getElementById('times-area');
  const wrap=document.createElement('div');wrap.className='times-wrap';
  times.forEach((time,ti)=>{
    const c=CORES[ti];
    const div=document.createElement('div');div.className='time-card';div.style.borderColor=c.cor;
    let rows='';
    time.forEach(j=>{const db=j.dbIdx>=0?state.jogadores[j.dbIdx]:null;const pos=j.posLista.length?j.posLista[0]:db?db.p:'';rows+=`<div class="time-row"><span style="flex:1;font-weight:${j.estrelas>=4?'500':'400'}">${j.nome}</span>${pos?`<span class="time-row-pos">${pos}</span>`:''}<span class="time-row-stars">${starsHtml(j.estrelas)}</span></div>`;});
    div.innerHTML=`<div class="time-hdr" style="background:${c.bg};color:${c.cor}">${c.nome}<span class="time-pts" style="color:${c.cor}">${Math.round(pesoTimes[ti])}pts</span></div><div class="time-body">${rows}</div>`;
    wrap.appendChild(div);
  });
  area.innerHTML='';area.appendChild(wrap);
}

