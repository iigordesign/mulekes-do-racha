<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mulekes do Racha</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --gold: #D3B474;
  --gold-dim: rgba(211,180,116,0.13);
  --gold-border: rgba(211,180,116,0.35);
  --bg: #0C0C0C;
  --bg2: #151515;
  --bg3: #1C1C1C;
  --bg4: #232323;
  --border: rgba(255,255,255,0.07);
  --border2: rgba(255,255,255,0.12);
  --text: #EFEFEF;
  --text2: #888;
  --text3: #444;
  --t-azul: #4A9EFF;
  --t-branco: #E8E8E8;
  --t-preto: #888;
  --t-dourado: #D3B474;
  --t-azul-bg: rgba(74,158,255,0.12);
  --t-branco-bg: rgba(232,232,232,0.08);
  --t-preto-bg: rgba(136,136,136,0.12);
  --t-dourado-bg: rgba(211,180,116,0.12);
  --red: #FF5A5A;
  --green: #4CAF7D;
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;min-height:100vh}

/* HEADER */
header{max-width:1040px;margin:0 auto;padding:28px 24px 0;display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:12px}
.logo h1{font-family:'Bebas Neue',sans-serif;font-size:clamp(38px,7vw,68px);letter-spacing:3px;color:var(--gold);line-height:1}
.logo p{font-size:12px;color:var(--text2);letter-spacing:2px;text-transform:uppercase;margin-top:3px}
.header-stat{background:var(--gold-dim);border:1px solid var(--gold-border);border-radius:20px;padding:5px 14px;font-size:12px;color:var(--gold);letter-spacing:.5px}

/* NAV */
nav{max-width:1040px;margin:20px auto 0;padding:0 24px;display:flex;gap:2px;border-bottom:1px solid var(--border);overflow-x:auto}
.nb{padding:10px 16px;background:none;border:none;border-bottom:2px solid transparent;color:var(--text2);font-family:'DM Sans',sans-serif;font-size:14px;font-weight:500;cursor:pointer;margin-bottom:-1px;white-space:nowrap;transition:all .15s}
.nb:hover{color:var(--text)}
.nb.active{color:var(--gold);border-bottom-color:var(--gold)}

/* MAIN */
main{max-width:1040px;margin:0 auto;padding:24px 24px 60px}
.page{display:none}.page.active{display:block}
.sec-head{margin-bottom:18px}
.sec-head h2{font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:1px;color:var(--text)}
.sec-head p{font-size:13px;color:var(--text2);margin-top:3px}

/* CARD BOX */
.box{background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:16px}
.box-title{font-family:'Bebas Neue',sans-serif;font-size:19px;letter-spacing:1px;margin-bottom:14px;color:var(--gold)}

/* BUTTONS */
.btn{padding:9px 20px;border-radius:8px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;cursor:pointer;transition:all .15s;border:1px solid var(--border)}
.btn-primary{background:var(--gold);color:#000;border-color:var(--gold)}
.btn-primary:hover{background:#c4a468}
.btn-primary:disabled{opacity:.4;cursor:not-allowed}
.btn-ghost{background:none;color:var(--text2)}
.btn-ghost:hover{border-color:var(--gold-border);color:var(--text)}
.btn-parse{width:100%;padding:11px;background:var(--bg3);border:1px solid var(--border);border-radius:8px;color:var(--gold);font-family:'DM Sans',sans-serif;font-size:14px;font-weight:500;cursor:pointer;margin-bottom:12px;transition:all .15s}
.btn-parse:hover{border-color:var(--gold-border);background:var(--gold-dim)}
.btn-sortear{padding:10px 28px;background:var(--gold);color:#000;border:none;border-radius:8px;font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:1px;cursor:pointer;transition:all .15s}
.btn-sortear:hover{background:#c4a468}
.btn-sortear:disabled{opacity:.4;cursor:not-allowed}
.action-btn{padding:3px 9px;border:1px solid var(--border);border-radius:4px;background:none;color:var(--text2);font-size:11px;cursor:pointer;transition:all .1s}
.action-btn:hover{border-color:var(--gold-border);color:var(--gold)}
.action-btn.del:hover{border-color:rgba(255,90,90,.4);color:var(--red)}

/* TEXTAREA */
.lista-ta{width:100%;min-height:220px;background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:14px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:14px;line-height:1.7;resize:vertical;transition:border .2s;margin-bottom:12px}
.lista-ta:focus{outline:none;border-color:var(--gold-border)}
.lista-ta::placeholder{color:var(--text3)}

/* PLAYER CARDS GRID */
.pg{display:grid;grid-template-columns:repeat(auto-fill,minmax(175px,1fr));gap:8px}
.pc{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:9px 11px;display:flex;align-items:center;gap:9px;cursor:pointer;transition:all .15s}
.pc:hover{border-color:var(--gold-border)}
.pc.sel{border-color:var(--gold);background:var(--gold-dim)}
.pc.conv{border-style:dashed}
.pc-num{width:24px;height:24px;border-radius:50%;background:var(--bg3);display:flex;align-items:center;justify-content:center;font-size:11px;color:var(--text2);flex-shrink:0;font-weight:600}
.pc.sel .pc-num{background:var(--gold);color:#000}
.pc-info{flex:1;min-width:0}
.pc-name{font-size:13px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.pc-meta{font-size:11px;color:var(--text2);margin-top:2px;display:flex;gap:4px;align-items:center;flex-wrap:wrap}
.chip{font-size:10px;padding:1px 5px;border-radius:3px;background:rgba(255,255,255,0.07);color:var(--text2)}
.chip-conv{background:rgba(211,180,116,.15);color:var(--gold)}
.inline-stars{display:flex;gap:2px;margin-top:3px}
.s{font-size:12px;cursor:pointer;color:var(--text3);user-select:none;transition:color .1s}
.s.on{color:#D3B474}

/* SORTEIO CONTROLS */
.sctrl{display:flex;align-items:center;flex-wrap:wrap;gap:10px;padding:12px 14px;background:var(--bg2);border:1px solid var(--border);border-radius:10px;margin-bottom:20px}
.sctrl-info{font-size:13px;color:var(--text2);flex:1}
.sctrl-info strong{color:var(--gold)}

/* TIMES */
.times-wrap{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px}
.time-card{border-radius:11px;overflow:hidden;border:1px solid var(--border)}
.time-hdr{padding:9px 13px;display:flex;justify-content:space-between;align-items:center;font-family:'Bebas Neue',sans-serif;font-size:17px;letter-spacing:1px}
.time-pts{font-family:'DM Sans',sans-serif;font-size:11px;font-weight:500;padding:2px 8px;border-radius:20px;background:rgba(0,0,0,.35)}
.time-body{padding:6px 0;background:var(--bg2)}
.time-row{padding:6px 13px;display:flex;align-items:center;gap:7px;border-bottom:1px solid var(--border);font-size:13px}
.time-row:last-child{border-bottom:none}
.time-row-pos{font-size:10px;padding:1px 5px;border-radius:3px;background:rgba(255,255,255,.07);color:var(--text2);flex-shrink:0}
.time-row-stars{font-size:10px;color:#D3B474;margin-left:auto}

/* TORNEIO */
.torneio-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:10px}
.jogo-card{background:var(--bg2);border:1px solid var(--border);border-radius:10px;overflow:hidden}
.jogo-hdr{padding:7px 12px;background:var(--bg3);font-size:11px;color:var(--text2);display:flex;justify-content:space-between;align-items:center;text-transform:uppercase;letter-spacing:.5px}
.jogo-hdr .jogo-status{font-size:10px;padding:2px 7px;border-radius:10px}
.status-pend{background:rgba(255,255,255,.07);color:var(--text3)}
.status-done{background:rgba(76,175,125,.15);color:var(--green)}
.jogo-body{padding:12px}
.jogo-times{display:flex;align-items:center;gap:8px}
.jogo-time{flex:1;text-align:center}
.jogo-time-name{font-family:'Bebas Neue',sans-serif;font-size:18px;letter-spacing:1px}
.jogo-time-gols{font-size:28px;font-weight:600;margin-top:2px}
.jogo-vs{font-size:13px;color:var(--text3);font-weight:600;flex-shrink:0}
.jogo-actions{display:flex;gap:6px;margin-top:10px;justify-content:center}
.goleadores-list{margin-top:8px;padding-top:8px;border-top:1px solid var(--border)}
.gol-badge{display:inline-flex;align-items:center;gap:4px;background:var(--bg3);border-radius:4px;padding:2px 7px;font-size:11px;margin:2px;color:var(--text2)}
.gol-badge .gol-time-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}

/* CLASSIFICAÇÃO */
.class-table{width:100%;border-collapse:collapse;font-size:13px}
.class-table th{text-align:left;padding:8px 12px;font-size:11px;color:var(--text2);text-transform:uppercase;letter-spacing:.5px;border-bottom:1px solid var(--border);font-weight:500}
.class-table td{padding:9px 12px;border-bottom:1px solid var(--border)}
.class-table tr:last-child td{border-bottom:none}
.class-table tr:hover td{background:rgba(255,255,255,.02)}
.class-table .num{font-weight:600;text-align:center}
.class-pos{font-size:12px;color:var(--text2);text-align:center}
.class-pos.top{color:var(--gold);font-weight:600}
.time-badge{display:inline-flex;align-items:center;gap:6px;font-weight:500}
.time-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}

/* PLACAR MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);display:flex;align-items:center;justify-content:center;z-index:100;padding:16px}
.modal{background:var(--bg2);border:1px solid var(--gold-border);border-radius:14px;width:100%;max-width:500px;max-height:90vh;overflow-y:auto}
.modal-hdr{padding:14px 18px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
.modal-hdr h3{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:1px;color:var(--gold)}
.modal-close{background:none;border:none;color:var(--text2);font-size:20px;cursor:pointer;padding:2px 6px}
.modal-close:hover{color:var(--text)}
.modal-body{padding:16px 18px}
.modal-footer{padding:12px 18px;border-top:1px solid var(--border);display:flex;gap:8px;justify-content:flex-end}
.gol-entry-row{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.gol-entry-row label{font-size:13px;flex:1}
.gol-entry-row input{width:56px;padding:6px 8px;background:var(--bg3);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:13px;font-family:'DM Sans',sans-serif;text-align:center}
.gol-entry-row input:focus{outline:none;border-color:var(--gold-border)}
.modal-section-title{font-size:11px;color:var(--text2);text-transform:uppercase;letter-spacing:.5px;margin:12px 0 8px}

/* FORM FIELDS */
.form-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;margin-bottom:12px}
.ff{display:flex;flex-direction:column;gap:5px}
.ff label{font-size:11px;color:var(--text2);text-transform:uppercase;letter-spacing:.5px}
.ff input,.ff select{padding:8px 10px;background:var(--bg2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:13px;transition:border .15s}
.ff input:focus,.ff select:focus{outline:none;border-color:var(--gold-border)}
.ff select option{background:var(--bg2)}

/* DATA TABLE */
.dt{width:100%;border-collapse:collapse;font-size:13px}
.dt th{text-align:left;padding:8px 12px;font-size:11px;color:var(--text2);text-transform:uppercase;letter-spacing:.5px;border-bottom:1px solid var(--border);font-weight:500}
.dt td{padding:8px 12px;border-bottom:1px solid var(--border)}
.dt tr:last-child td{border-bottom:none}
.dt tr:hover td{background:rgba(255,255,255,.02)}
.dt .num{font-weight:600}

/* INNER TABS */
.itabs{display:flex;gap:6px;margin-bottom:16px;flex-wrap:wrap}
.itab{padding:5px 13px;border-radius:20px;background:var(--bg2);border:1px solid var(--border);color:var(--text2);font-size:13px;cursor:pointer;transition:all .15s}
.itab.active{background:var(--gold-dim);border-color:var(--gold-border);color:var(--gold)}

/* ALERT */
.alert{padding:9px 13px;border-radius:8px;font-size:13px;margin-bottom:12px}
.alert-ok{background:rgba(76,175,125,.12);border:1px solid rgba(76,175,125,.3);color:var(--green)}
.alert-err{background:rgba(255,90,90,.1);border:1px solid rgba(255,90,90,.3);color:var(--red)}

/* STATUS ATIVO */
.badge-ativo{font-size:10px;padding:1px 6px;border-radius:3px;background:rgba(76,175,125,.15);color:var(--green)}
.badge-inativo{font-size:10px;padding:1px 6px;border-radius:3px;background:rgba(255,90,90,.1);color:var(--red)}

/* MISC */
.empty{text-align:center;padding:40px;color:var(--text3);font-size:14px}
.tw{overflow-x:auto}
.row-gap{display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-bottom:14px}

@media(max-width:600px){
  header{padding:18px 16px 0}
  nav{padding:0 16px}
  main{padding:18px 16px 60px}
}
</style>
</head>
<body>

<header>
  <div class="logo">
    <h1>Mulekes do Racha</h1>
    <p>Sistema de sorteio e torneio</p>
  </div>
  <div class="header-stat" id="hstat">Carregando...</div>
</header>

<nav>
  <button class="nb active" onclick="showPage('sorteio',this)">Sorteio</button>
  <button class="nb" onclick="showPage('torneio',this)">Torneio</button>
  <button class="nb" onclick="showPage('jogadores',this)">Jogadores</button>
  <button class="nb" onclick="showPage('artilharia',this)">Artilharia</button>
</nav>

<main>

<!-- ======= SORTEIO ======= -->
<div id="page-sorteio" class="page active">
  <div class="sec-head"><h2>Lista da Semana</h2><p>Cole a lista no formato padrão, ajuste as estrelas e sorteie.</p></div>
  <textarea class="lista-ta" id="lista-input" placeholder="Cole a lista aqui. Exemplo:
01 - Mauro Juin - zag
02 - Igor - ata
03 - Ryan - ata, zag
04 - Davi (Chico) - ata
05 - Lázarope (iago)"></textarea>
  <button class="btn-parse" onclick="processarLista()">Processar lista →</button>
  <div id="parsed-area" style="display:none">
    <div style="margin-bottom:10px">
      <div class="row-gap">
        <span style="font-size:12px;color:var(--text2)">Clique para selecionar/deselecionar</span>
        <button class="btn ghost btn-ghost btn" style="padding:5px 12px;font-size:12px" onclick="toggleAll(true)">Todos</button>
        <button class="btn btn-ghost" style="padding:5px 12px;font-size:12px" onclick="toggleAll(false)">Nenhum</button>
      </div>
      <div class="pg" id="players-grid"></div>
    </div>
    <div class="sctrl">
      <div class="sctrl-info" id="sctrl-info">Selecione jogadores</div>
      <button class="btn btn-ghost" onclick="resetSorteio()">Limpar</button>
      <button class="btn-sortear" id="btn-sortear" onclick="sortear()" disabled>Sortear</button>
    </div>
    <div id="times-area"></div>
  </div>
</div>

<!-- ======= TORNEIO ======= -->
<div id="page-torneio" class="page">
  <div class="sec-head"><h2>Torneio</h2><p>Rodada completa: fase de grupos + semifinais. Registre os placares e veja a classificação.</p></div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px" id="torneio-top">
    <div class="box">
      <div class="box-title">Classificação</div>
      <div class="tw"><table class="class-table" id="class-table">
        <thead><tr><th>#</th><th>Time</th><th>J</th><th>V</th><th>D</th><th>GP</th><th>GC</th><th>SG</th></tr></thead>
        <tbody id="class-tbody"></tbody>
      </table></div>
    </div>
    <div class="box">
      <div class="box-title">Artilharia do Torneio</div>
      <table class="dt" id="tart-table">
        <thead><tr><th>#</th><th>Jogador</th><th>Time</th><th>Gols</th></tr></thead>
        <tbody id="tart-tbody"></tbody>
      </table>
    </div>
  </div>

  <div class="box" style="margin-bottom:16px">
    <div class="box-title">Fase de Grupos</div>
    <div class="torneio-grid" id="jogos-grid"></div>
  </div>

  <div class="box" id="semis-box">
    <div class="box-title">Semifinais</div>
    <div class="torneio-grid" id="semis-grid"></div>
  </div>
</div>

<!-- ======= JOGADORES ======= -->
<div id="page-jogadores" class="page">
  <div class="sec-head"><h2>Jogadores</h2><p>Base de dados completa. Gerencie estrelas, posições e histórico.</p></div>
  <div class="box" style="margin-bottom:18px">
    <div class="box-title">Adicionar jogador</div>
    <div class="form-grid">
      <div class="ff"><label>Nome</label><input id="f-nome" placeholder="Ex: Igor"/></div>
      <div class="ff"><label>Estrelas (1–5)</label><input id="f-stars" type="number" min="1" max="5" value="3"/></div>
      <div class="ff"><label>Posição principal</label>
        <select id="f-pos"><option value="">Indefinida</option><option value="ATA">Atacante</option><option value="MEI">Meia</option><option value="ZAG">Zagueiro</option><option value="LAT">Lateral</option><option value="VOL">Volante</option></select>
      </div>
      <div class="ff"><label>Posição secundária</label>
        <select id="f-pos2"><option value="">Nenhuma</option><option value="ATA">Atacante</option><option value="MEI">Meia</option><option value="ZAG">Zagueiro</option><option value="LAT">Lateral</option><option value="VOL">Volante</option></select>
      </div>
    </div>
    <button class="btn btn-primary" onclick="addPlayer()">+ Adicionar</button>
  </div>
  <div class="tw"><table class="dt" id="jog-table">
    <thead><tr><th>Nome</th><th>Estrelas</th><th>Posição</th><th>Status</th><th>Gols</th><th>MVP</th><th>Camp.</th><th></th></tr></thead>
    <tbody id="jog-tbody"></tbody>
  </table></div>
</div>

<!-- ======= ARTILHARIA ======= -->
<div id="page-artilharia" class="page">
  <div class="sec-head"><h2>Artilharia & Stats</h2></div>
  <div class="itabs">
    <button class="itab active" onclick="showItab('gols',this)">Gols</button>
    <button class="itab" onclick="showItab('mvp',this)">MVPs</button>
    <button class="itab" onclick="showItab('camp',this)">Títulos</button>
  </div>
  <div class="tw"><table class="dt">
    <thead><tr><th>#</th><th>Jogador</th><th>Posição</th><th id="art-col">Gols</th><th>Estrelas</th></tr></thead>
    <tbody id="art-tbody"></tbody>
  </table></div>
</div>

</main>

<!-- ======= MODAL PLACAR ======= -->
<div class="modal-overlay" id="modal" style="display:none" onclick="fecharModal(event)">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-hdr">
      <h3 id="modal-title">Placar</h3>
      <button class="modal-close" onclick="fecharModal()">✕</button>
    </div>
    <div class="modal-body" id="modal-body"></div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="fecharModal()">Cancelar</button>
      <button class="btn btn-primary" onclick="salvarPlacar()">Salvar placar</button>
    </div>
  </div>
</div>

<!-- ======= MODAL EDITAR JOGADOR ======= -->
<div class="modal-overlay" id="modal-edit" style="display:none" onclick="fecharModalEdit(event)">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-hdr">
      <h3>Editar jogador</h3>
      <button class="modal-close" onclick="fecharModalEdit()">✕</button>
    </div>
    <div class="modal-body" id="modal-edit-body"></div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="fecharModalEdit()">Cancelar</button>
      <button class="btn btn-primary" onclick="salvarEdicao()">Salvar</button>
    </div>
  </div>
</div>

<script>
const KEY = 'mulekes_v4';
const TIMES_TORNEIO = [
  {id:'azul', nome:'Azul', cor:'#4A9EFF', bg:'rgba(74,158,255,.12)'},
  {id:'branco', nome:'Branco', cor:'#E8E8E8', bg:'rgba(232,232,232,.08)'},
  {id:'preto', nome:'Preto', cor:'#999', bg:'rgba(136,136,136,.12)'},
  {id:'dourado', nome:'Dourado', cor:'#D3B474', bg:'rgba(211,180,116,.12)'},
];
const JOGOS_BASE = [
  {id:'j1',label:'Jogo 1',fase:'grupo',t1:'azul',t2:'branco'},
  {id:'j2',label:'Jogo 2',fase:'grupo',t1:'preto',t2:'dourado'},
  {id:'j3',label:'Jogo 3',fase:'grupo',t1:'azul',t2:'dourado'},
  {id:'j4',label:'Jogo 4',fase:'grupo',t1:'branco',t2:'preto'},
  {id:'j5',label:'Jogo 5',fase:'grupo',t1:'azul',t2:'preto'},
  {id:'j6',label:'Jogo 6',fase:'grupo',t1:'dourado',t2:'branco'},
  {id:'s1',label:'Semi 1',fase:'semi',t1:'1º',t2:'4º',dinamico:true},
  {id:'s2',label:'Semi 2',fase:'semi',t1:'2º',t2:'3º',dinamico:true},
