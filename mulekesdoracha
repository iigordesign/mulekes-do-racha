      <div class="pc-meta">${pos?`<span class="chip">${pos}</span>`:''}${j.convidadoPor?`<span class="chip chip-conv">conv. ${j.convidadoPor}</span>`:''}</div>
      <div class="inline-stars" id="st${i}">${renderStars(i,j.estrelas)}</div>
    </div>`;
    div.onclick=e=>{if(!e.target.classList.contains('s'))toggleCard(i);};
    grid.appendChild(div);
  });
  updCtrl();
}
function renderStars(i,v){let s='';for(let x=1;x<=5;x++)s+=`<span class="s ${x<=v?'on':''}" onclick="event.stopPropagation();setStar(${i},${x})">★</span>`;return s;}
function setStar(i,v){semanaAtual[i].estrelas=v;document.getElementById('st'+i).innerHTML=renderStars(i,v);}
function toggleCard(i){semanaAtual[i].selected=!semanaAtual[i].selected;const c=document.getElementById('pc'+i);c.classList.toggle('sel',semanaAtual[i].selected);if(semanaAtual[i].selected)selecionados.add(i);else selecionados.delete(i);updCtrl();}
