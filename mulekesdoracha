// ---- UTILS ----
function norm(s){return s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/[^a-z0-9 ]/g,'').trim();}
function findJ(nome){
  const n=norm(nome);
  return state.jogadores.findIndex(j=>{
    const b=norm(j.n.replace(/\s*\(.*?\)\s*/g,''));
    const f=norm(j.n);
    return f===n||b===n||f.startsWith(n)||n.startsWith(b);
  });
}
function peso(j){return(j.s||1)*10+(j.mvp||0)*1.5+(j.camp||0)*2+Math.min(j.gols||0,30)*.08;}
function shuffle(a){const r=[...a];for(let i=r.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[r[i],r[j]]=[r[j],r[i]];}return r;}
function starsHtml(n){return'★'.repeat(n)+'☆'.repeat(5-n);}
function timeInfo(id){return TIMES_TORNEIO.find(t=>t.id===id)||{nome:id,cor:'#888',bg:'rgba(128,128,128,.1)'};}
function posPosicoes(p,p2){let r=p||'';if(p2)r+=(r?'/'+p2:p2);return r||'—';}

function classificacao(){
  const pts={azul:{v:0,d:0,gp:0,gc:0},branco:{v:0,d:0,gp:0,gc:0},preto:{v:0,d:0,gp:0,gc:0},dourado:{v:0,d:0,gp:0,gc:0}};
  state.jogos.filter(j=>j.fase==='grupo'&&j.gols1!==null).forEach(j=>{
    pts[j.t1].gp+=j.gols1;pts[j.t1].gc+=j.gols2;
    pts[j.t2].gp+=j.gols2;pts[j.t2].gc+=j.gols1;
    if(j.gols1>j.gols2){pts[j.t1].v++;pts[j.t2].d++;}
    else if(j.gols2>j.gols1){pts[j.t2].v++;pts[j.t1].d++;}
    else{pts[j.t1].v+=0;pts[j.t2].v+=0;}
  });
  return TIMES_TORNEIO.map(t=>({...t,...pts[t.id],j:(pts[t.id].v+pts[t.id].d),sg:pts[t.id].gp-pts[t.id].gc}))
    .sort((a,b)=>b.v-a.v||b.sg-a.sg||b.gp-a.gp);
}

// artilharia do torneio
function artTorneio(){
  const map={};
  state.jogos.forEach(j=>{
    (j.goleadores||[]).forEach(g=>{
      if(!map[g.nome])map[g.nome]={nome:g.nome,time:g.time,gols:0};
      map[g.nome].gols+=g.qtd;
    });
  });
  return Object.values(map).sort((a,b)=>b.gols-a.gols).slice(0,10);
}

