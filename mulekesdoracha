  (jogo.goleadores||[]).forEach(g=>{
    const idx=state.jogadores.findIndex(j=>j.n===g.nome);
    if(idx>=0)state.jogadores[idx].gols=Math.max(0,(state.jogadores[idx].gols||0)-g.qtd);
  });

  jAtivos.forEach((j,i)=>{
    const v1=parseInt(document.getElementById(`gt1-${i}`).value)||0;
    const v2=parseInt(document.getElementById(`gt2-${i}`).value)||0;
    if(v1>0)goleadores.push({nome:j.n,time:jogo.t1,qtd:v1});
    if(v2>0)goleadores.push({nome:j.n,time:jogo.t2,qtd:v2});
    // adicionar gols novos
    const dbIdx=state.jogadores.findIndex(jj=>jj.n===j.n);
    if(dbIdx>=0){state.jogadores[dbIdx].gols=(state.jogadores[dbIdx].gols||0)+v1+v2;}
  });

  jogo.gols1=g1;jogo.gols2=g2;jogo.goleadores=goleadores;
  save();
  fecharModal();
  renderTorneio();
  renderArtilharia_page();
  updateHeader();
}

function limparJogo(id){
  if(!confirm('Limpar placar deste jogo?'))return;
  const jogo=state.jogos.find(j=>j.id===id);
  (jogo.goleadores||[]).forEach(g=>{const idx=state.jogadores.findIndex(j=>j.n===g.nome);if(idx>=0)state.jogadores[idx].gols=Math.max(0,(state.jogadores[idx].gols||0)-g.qtd);});
  jogo.gols1=null;jogo.gols2=null;jogo.goleadores=[];
  save();renderTorneio();renderArtilharia_page();
}

function fecharModal(e){if(e&&e.target!==document.getElementById('modal'))return;document.getElementById('modal').style.display='none';}

// ---- JOGADORES PAGE ----
function renderJogadores(){
  const tbody=document.getElementById('jog-tbody');
  tbody.innerHTML=state.jogadores.map((j,i)=>`<tr>
    <td>${j.n}</td>
    <td style="color:#D3B474;font-size:12px">${starsHtml(j.s)}</td>
    <td>${posPosicoes(j.p,j.p2)}</td>
    <td><span class="${j.ativo!==false?'badge-ativo':'badge-inativo'}">${j.ativo!==false?'Ativo':'Inativo'}</span></td>
    <td class="num">${j.gols||0}</td>
    <td class="num">${j.mvp||0}</td>
    <td class="num">${j.camp||0}</td>
    <td>
      <button class="action-btn" onclick="abrirEdit(${i})">Editar</button>
      <button class="action-btn del" onclick="delJogador(${i})">Remover</button>
    </td>
  </tr>`).join('');
  updateHeader();
}

function addPlayer(){
  const n=document.getElementById('f-nome').value.trim();
  if(!n)return alert('Informe o nome');
  state.jogadores.push({n,s:parseInt(document.getElementById('f-stars').value)||3,p:document.getElementById('f-pos').value,p2:document.getElementById('f-pos2').value,gols:0,mvp:0,camp:0,ativo:true});
  save();document.getElementById('f-nome').value='';renderJogadores();
}

function delJogador(i){if(!confirm(`Remover ${state.jogadores[i].n}?`))return;state.jogadores.splice(i,1);save();renderJogadores();}

// ---- MODAL EDITAR JOGADOR ----
function abrirEdit(i){
  editIdx=i;
  const j=state.jogadores[i];
  const body=document.getElementById('modal-edit-body');
  body.innerHTML=`
    <div class="form-grid">
      <div class="ff"><label>Nome</label><input id="e-nome" value="${j.n}"></div>
      <div class="ff"><label>Estrelas (1–5)</label><input id="e-stars" type="number" min="1" max="5" value="${j.s}"></div>
      <div class="ff"><label>Posição principal</label>
        <select id="e-pos"><option value="">Indefinida</option><option value="ATA" ${j.p==='ATA'?'selected':''}>Atacante</option><option value="MEI" ${j.p==='MEI'?'selected':''}>Meia</option><option value="ZAG" ${j.p==='ZAG'?'selected':''}>Zagueiro</option><option value="LAT" ${j.p==='LAT'?'selected':''}>Lateral</option><option value="VOL" ${j.p==='VOL'?'selected':''}>Volante</option></select>
      </div>
      <div class="ff"><label>Posição secundária</label>
        <select id="e-pos2"><option value="">Nenhuma</option><option value="ATA" ${j.p2==='ATA'?'selected':''}>Atacante</option><option value="MEI" ${j.p2==='MEI'?'selected':''}>Meia</option><option value="ZAG" ${j.p2==='ZAG'?'selected':''}>Zagueiro</option><option value="LAT" ${j.p2==='LAT'?'selected':''}>Lateral</option><option value="VOL" ${j.p2==='VOL'?'selected':''}>Volante</option></select>
      </div>
      <div class="ff"><label>Status</label>
        <select id="e-ativo"><option value="1" ${j.ativo!==false?'selected':''}>Ativo</option><option value="0" ${j.ativo===false?'selected':''}>Inativo</option></select>
      </div>
    </div>
    <div style="border-top:1px solid var(--border);padding-top:14px;margin-top:4px">
      <div style="font-size:11px;color:var(--text2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px">Corrigir histórico</div>
      <div class="form-grid">
        <div class="ff"><label>Gols totais</label><input id="e-gols" type="number" min="0" value="${j.gols||0}"></div>
        <div class="ff"><label>MVPs</label><input id="e-mvp" type="number" min="0" value="${j.mvp||0}"></div>
        <div class="ff"><label>Títulos</label><input id="e-camp" type="number" min="0" value="${j.camp||0}"></div>
      </div>
    </div>
    <div style="border-top:1px solid var(--border);padding-top:12px;margin-top:4px">
      <div style="font-size:11px;color:var(--text2);margin-bottom:6px">Inativo = o jogador some do sorteio mas o histórico é mantido</div>
    </div>`;
  document.getElementById('modal-edit').style.display='flex';
}

function salvarEdicao(){
  if(editIdx===null)return;
  const j=state.jogadores[editIdx];
  j.n=document.getElementById('e-nome').value.trim()||j.n;
  j.s=Math.min(5,Math.max(1,parseInt(document.getElementById('e-stars').value)||j.s));
  j.p=document.getElementById('e-pos').value;
  j.p2=document.getElementById('e-pos2').value;
  j.ativo=document.getElementById('e-ativo').value==='1';
  j.gols=parseInt(document.getElementById('e-gols').value)||0;
  j.mvp=parseInt(document.getElementById('e-mvp').value)||0;
  j.camp=parseInt(document.getElementById('e-camp').value)||0;
  save();fecharModalEdit();renderJogadores();renderArtilharia_page();
}

function fecharModalEdit(e){if(e&&e.target!==document.getElementById('modal-edit'))return;document.getElementById('modal-edit').style.display='none';}

// ---- ARTILHARIA ----
let artItab='gols';
function renderArtilharia_page(){
  const sorted=[...state.jogadores].filter(j=>j.ativo!==false);
  let key,label;
  if(artItab==='gols'){sorted.sort((a,b)=>(b.gols||0)-(a.gols||0));key='gols';label='Gols';}
  else if(artItab==='mvp'){sorted.sort((a,b)=>(b.mvp||0)-(a.mvp||0));key='mvp';label='MVPs';}
  else{sorted.sort((a,b)=>(b.camp||0)-(a.camp||0));key='camp';label='Títulos';}
  document.getElementById('art-col').textContent=label;
  const medals=['🥇','🥈','🥉'];
  document.getElementById('art-tbody').innerHTML=sorted.map((j,i)=>`<tr class="${i===0?'top-row':''}">
    <td>${i<3?medals[i]:`${i+1}`}</td>
    <td>${j.n}</td><td>${posPosicoes(j.p,j.p2)}</td>
    <td class="num">${j[key]||0}</td>
    <td style="color:#D3B474;font-size:11px">${starsHtml(j.s)}</td>
  </tr>`).join('');
}

function showItab(tab,el){
  artItab=tab;
  document.querySelectorAll('.itab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  renderArtilharia_page();
}

// ---- HEADER ----
function updateHeader(){document.getElementById('hstat').textContent=`${state.jogadores.filter(j=>j.ativo!==false).length} jogadores ativos`;}

// ---- PAGES ----
function showPage(p,el){
  document.querySelectorAll('.page').forEach(x=>x.classList.remove('active'));
  document.querySelectorAll('.nb').forEach(x=>x.classList.remove('active'));
  document.getElementById('page-'+p).classList.add('active');
  el.classList.add('active');
  if(p==='torneio')renderTorneio();
  if(p==='jogadores')renderJogadores();
  if(p==='artilharia')renderArtilharia_page();
}

// ---- INIT ----
updateHeader();
renderJogadores();
</script>
</body>
</html>
